#!/bin/zsh

# Set session name
SESSION="Console"
SESSIONEXISTS=$(tmux list-sessions | grep $SESSION)
WORKDIR=~/Projects
if [[ $# -eq 1 ]]; then
  WORKDIR=$1
fi

# activate the virtual environment
# cd $WORKDIR
# if [[ "$OSTYPE" == "darwin"* ]]; then
# 	$(poetry env activate)
# else
# 	poetry shell
# fi

# Only create a tmux session if it doesn't already exist
if [ "$SESSIONEXISTS" = "" ]; then
  cd $WORKDIR

  # start new session with our name
  tmux new-session -d -s $SESSION

  # Name first Pane and start ssh
  tmux rename-window -t 1 'IDE'
  tmux send-keys -t $SESSION -c $WORKDIR "v" 'C-m'
  tmux split-window -v
  tmux send-keys -t $SESSION -c $WORKDIR 'C-m'
  tmux resize-pane -D 5
  tmux select-pane -U
  tmux new-window -t $SESSION:2 -n 'AI'
  tmux send-keys -t $SESSION "cd $WORKDIR;" 'C-m'
fi

# Attach session, on Main Window
tmux attach-session -t $SESSION
