#!/bin/zsh

# Generate a unique session name
SESSION="s-${$(date +%s):0:4}"

# Create a new detached session with a window named 'IDE'
tmux new-session -d -s "$SESSION" -n 'IDE'

# Split the window horizontally: 70% Left, 30% Right
tmux split-window -h -p 30

# Move back to the left pane and split it vertically: 70% Top, 30% Bottom
tmux select-pane -L
tmux split-window -v -p 30

# Move focus back to the top-left pane
tmux select-pane -U

sleep 0.1
# Start nvim in the top-left pane
tmux send-keys "nvim" C-m

# Attach to the session
tmux attach-session -t "$SESSION"
